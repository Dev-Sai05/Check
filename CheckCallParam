sub process(){
    my $arg ;
    my $subCob ;
    my $dest ;
    my $lineSt = "";
    my $lineNo = 0 ; 
    my @tmpArr = () ;
    my $tmpVat = "";
    my $callLine = 0 ;
   
     #print "input file : $inputfile\n ";
    open(DATA, '<', $inputfile) or die "Couldn't open $inputfile , $!";
    while ($line = <DATA>) {
        $lineNo = $lineNo + 1 ; 
        next if($line =~ m/^......\*/ || $line =~ m/^\s*$/);
        #if($line =~ m/CALL\s+\"([A-Z0-9]+)\"\s+USING\s+(.*)/ && $line !~ m/\"DBIO\"/ ){
        if($line =~ m/CALL\s+[\"\']([A-Z0-9]+)[\"\']\s+USING\s+(.*)/ && $line !~ m/\"DBIO\"/ ){
            print "Found CALL $1\n" if($debug);
            $callLine = $lineNo ; 
            @tmpArr = () ;

            ($subCob, $arg) = ( $line =~ /^......\s+CALL\s+[\"\']([A-Z0-9]+)[\"\']\s+USING\s+([A-Z0-9\-\.]*)\s*/ );
            $arg =~ s/\.//g;
            if($subCob =~ m/^UT/){
                print "Skiping for $subCob\n" if($debug);
                next ;
            }
            $tmpVat = $tmpVat . "	$subCob" ;

            if($arg eq ""){
                $lineNo = $lineNo + 1 ; 
                $nextline = <DATA> ;
                if($nextline =~ m/^......\s*([a-zA-Z0-9\-]+)\s*.*/ ){
                    $tmpVat = $tmpVat . "|$1" ;
                    push(@tmpArr,$1) if($1);
                }
            } 
            else{
                $tmpVat = $tmpVat . "|$arg" if($arg);
                push(@tmpArr,$arg) if($arg);
            }

            $nextline = <DATA> ;
            $lineNo = $lineNo + 1 ; 
            while(1){
               chomp($nextline);
               if($nextline =~ m/^......\*/ || $nextline =~ m/Micro Focus/ || $nextline =~ m/^\s*$/){
                   $lineNo = $lineNo + 1 ; 
                   $nextline = <DATA> ;
                   next ;
               }
               ($arg) = ( $nextline =~ /^......\s*([a-zA-Z0-9\-]+)\s*.*/ );
               if( grep( /$arg/, @cobolKeywords) || $arg =~ m/EXIT/){
                   last ;
               }
               $tmpVat = $tmpVat . "|$arg" if($arg);
               push(@tmpArr,$arg) if($arg);
               $lineNo = $lineNo + 1 ; 
               $nextline = <DATA> ;
            }
        }
        validateParam($subCob, \@tmpArr, $callLine) if(@tmpArr);
        $subCob = "" ;
        @tmpArr = () ;
    } 
    close(DATA);
}


sub uncompressFile($){

    my $subCOB = $_[0];

    my $mflistFile = "$mflistdir/$subCOB\.Z";
    my $cpFile = "$tmpUnCompressDir/$subCOB\.Z";
    my $rs = "ERR";
    
    if(!-e $mflistFile){
        print "$mflistFile not available\n" if($debug);
        return "ERR";
    }
    my $cpst = `cp -f $mflistFile $cpFile`;

    if($? == 0){
        print "Copy $subCOB\.Z to $tmpUnCompressDir\n" if($debug);
        my $unComSt = `uncompress $cpFile`;
        if($? == 0){
            print "Uncompress done for $cpFile\n" if ($debug);
            $rs = "OK:$tmpUnCompressDir/$subCOB";
        }
        else{
            print "Uncompress failed for $cpFile \n" if ($debug);
            $rs = "ERR" ;
        }
   
    }
    return $rs;
}

sub initiateHashForSubCOB($$){

    my $subCOBfile = $_[0];
    my $subCOBName = $_[1];
    my $ln ;
    my $param ;
    my $param_1 ;
    my $nextln ;
    my $lastck = 0 ;
    my @tmpSubCobParam = ();

    generateHash_variablesSUBCOB($subCOBfile);
 
    open(COBFILE, '<', $subCOBfile) or die "Couldn't open $subCOB, $!";
    while ($ln = <COBFILE>) {
        $lastck = 0;
        chomp($ln);
        #if($ln =~ m/^......\s+PROCEDURE\s+DIVISION\s+USING\s+([a-zA-Z0-9\-\.]+)\s*$/ || $ln =~ m/^......\s+PROCEDURE\s+DIVISION\s+USING([a-zA-Z0-9\-\.]+)\s*$/){
        if($ln =~ m/^......\s+PROCEDURE\s+DIVISION\s+USING\s+([a-zA-Z0-9\-\.]+)\s*$/ || $ln =~ m/^......\s+PROCEDURE\s+DIVISION\s+USING([a-zA-Z0-9\-\.]+)\s*$/ || $ln =~ m/^......\s+PROCEDURE\s+DIVISION\s+USING\s*$/){
                print "Found [$ln]\n" if($debug);
                $lastck = 1;
                $param = $1 ;
                $param =~ s/^\s*|\s*$//g;
 
                if($param eq ""){
                    $nextln = <COBFILE> ;
                    if($nextln =~ m/^......\s*([a-zA-Z0-9\-\.]+)\s*.*/){
                        $param = $1 ;
                        $param =~ s/^\s*|\s*$//g;
                        $param_1 = $param ;
                        $param_1 =~ s/\.//g;
                        push(@tmpSubCobParam, $param_1) if($param);
                        $subcallHash{$subCOBName} = \@tmpSubCobParam ;
                    }
                }
                else{
                    $param_1 = $param ;
                    $param_1 =~ s/\.//g;
                    push(@tmpSubCobParam, $param_1) if($param);
                    $subcallHash{$subCOBName} = \@tmpSubCobParam ;
                }

                $nextln = <COBFILE> ;

                while(1){
                    chomp($nextln);       
                    if($nextln =~ m/^......\*/ || $nextln =~ m/Micro Focus|PARA/ || $nextln =~ m/^\s*$/){
                        $nextln = <COBFILE> ;
                        next ;
                    }
                    last if($nextln =~ /^...... [a-zA-Z0-9\-\.]+/) ;
                    ($param) = ( $nextln =~ /^......\s*([a-zA-Z0-9\-\.]+)\s*.*/ );
                    if( grep( /$param/, @cobolKeywords) || $param =~ m/EXIT/ || $param =~ m/\s+SECTION|MAIN-LINE|MAINLINE|BEGIN|MAIN-PROCESS/){
                        #print "exit LINE : $nextln\n" if($debug);
                        last ;
                    }
                    $param =~ s/^\s*|\s*$//g;
                    $param_1 = $param ;
                    $param_1 =~ s/\.//g;
                    push(@tmpSubCobParam, $param_1) if($param);
                    $subcallHash{$subCOBName} = \@tmpSubCobParam ;
                    $nextln = <COBFILE> ;
                }
        }
         
        if($lastck == 1){
            $subcallHash{$subCOBName} = \@tmpSubCobParam ;
            `rm $subCOBfile` if(-f $subCOBfile);
            last ;
        }
    }

    `rm $subCOBfile` if(-f $subCOBfile);
    close(COBFILE);
}

sub checkPCOfile($){
    my $subCOB =  $_[0] ;
    
    if(-e "$pcodir/$subCOB\.PCO"){
        print "$pcodir/$subCOB found $tmpUnCompressDir/$subCOB\.PCO\n" if($debug) ; 
        my $cpst = `cp -f "$pcodir/$subCOB\.PCO" "$tmpUnCompressDir/$subCOB\.PCO"`;
   
        if($? == 0){
            print "Copy done from $pcodir/$subCOB\.PCO to $tmpUnCompressDir/$subCOB\.PCO\n" if ($debug);
            return "OK:$tmpUnCompressDir/$subCOB\.PCO";
        }
        else{
            print "Copy failed for $tmpUnCompressDir/$subCOB\.PCO \n" if ($debug);
            return "ERR" ;
        } 
        
    }
    return "ERR" ;
}

sub validateParam($$$){
    my $subCOB = $_[0];
    my @arglist = @{$_[1]};
    my $lineNo = $_[2];

    if(defined($subcallHash{$subCOB})){
        print "Already Defined : [$subCOB -> @{$subcallHash{$subCOB}}]\n" if($debug); 
        my $cmpSt = compareArray(\@arglist,\@{$subcallHash{$subCOB}},$subCOB);
        print "$lineNo:Compare Status $cmpSt:$subCOB\n\n" if($cmpSt eq "ERR") ;
    }
    else {
        print "Not Already Defined\n" if($debug); 
        my $unStatus = uncompressFile($subCOB);
        if($unStatus eq "ERR"){
            $unStatus = checkPCOfile($subCOB);
        }
	my($s, $file) = split(/\:/, $unStatus);
        if($unStatus =~ m/OK:/){
            initiateHashForSubCOB($file,$subCOB);
            if(defined($subcallHash{$subCOB})){
                my $cmpSt = compareArray(\@arglist,\@{$subcallHash{$subCOB}},$subCOB);
                print "$lineNo:Compare Status $cmpSt:$subCOB\n\n" if($cmpSt eq "ERR");
            }
        }
    } 
}


