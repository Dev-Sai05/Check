sub init(){

    &EvaP( \@PDT, \@MM, \%cmdarg );
    $inputfile  = $cmdarg{'inputfile'} ;
    $outputfile  = $cmdarg{'outputfile'} ;
    $debug  = $cmdarg{'debug'} ;

    if(!-e $inputfile || !-r $inputfile){
        print "$inputfile not exists or readable\n";
        exit;
    }

    if($outputfile eq ""){
        my $inpFileName = basename($inputfile);
        $outputfile = "/tmp/$LOGNAME/$inpFileName\_Init.err";
    }
}


sub generateHash_variables($){

    my $var = "";
    my $datatype = "";

    my $inFile = $_[0] ; 
    my $COBNAME = $inFile ; 
 
    $COBNAME =~ s/\.COB|\.PCO//i;

#print "\n*-*-*-*-*-$COBNAME-*-*-*-*\n";


    my %tmpHash = () ;
   
       
    open(DATA, '<', $inFile) or die "Couldn't open $inputfile , $!";
    while(<DATA>) {
       ($var, $datatype) = "";
       next if($_ =~ m/^......\*/);
        
         
       #if($_ =~ m/^.*\s+\d{2}\s+(.*)\s+(PIC\s+.).*\./){
       if($_ =~ m/^.*\s+\d{2}\s+(.*)\s+(PIC\s+.)(\(.*?\))[\.|\s+]/){
           my $key = $1 ;
           my $value = $2 ;
	   my $lenght = $3 ;
	#print "\n$key----$value-------$lenght\n";exit;
           $key=~ s/^\s+|\s+$//g;
           $value=~ s/^\s+|\s+$//g;
	
           $value=~ s/\s+/ /g;
	   $lenght =~s/\((.*?)\)/$1/g;
           chomp($key);
           chomp($value);
           chomp($lenght);

           $tmpHash{$key}->{'VAL'} = $value ;
           $tmpHash{$key}->{'LEN'} = $lenght ;
       }
    }
    close(DATA);
    #print Dumper \%tmpHash;
    return %tmpHash ;
}

