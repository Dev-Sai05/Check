#--------------------------------------------------
# Function validateVariables
# Validate the source and destination variables
# and their data types


sub validateVariables($$$){

    my $srcVar = $_[0] ;
    my $destVar = $_[1] ;
    my $lineNum = $_[2] ;
    my $ret ;
    
   # if($srcVar !~ m/\d+|\'.*\'|\".*\"|ZEROES|ZEROS|ZERO|SPACES|SPACE/ && !defined($varHash{$srcVar})){
   if($srcVar =~ m/\d+|\'.*\'|\".*\"/){
      $srcVar =~ s/'|"//g;
      #$len = length($srcVar);
      #$srcVar = $srcVar ."_".$len;
     # print "src : $srcVar \n";
    
    }
    #print "$varHash{$srcVar} , $varHash{$destVar}";
    if($varHash{$srcVar} eq $varHash{$destVar}){


        $ret = "OK $srcVar:$varHash{$srcVar}  $destVar:$varHash{$destVar}";
    }
    else{
                 
	#      if ($varHash{$srcVar}){
        if ($varHash{$srcVar} || $varHash{$destVar}){
        if ((($varHash{$srcVar}=~m/PIC_9/ && $varHash{$destVar}!~m/PIC_9/)) || (($varHash{$srcVar}=~m/PIC_X/ && $varHash{$destVar}!~m/PIC_X/ )) || (($varHash{$srcVar}=~m/PIC_S/ && $varHash{$destVar}!~m/PIC_S/))){

        $ret = "ERR $srcVar:$varHash{$srcVar}  $destVar:$varHash{$destVar}";
        }
        }
        elsif(($srcVar =~m/\d{1,}/ && $varHash{$destVar}!~m/PIC_9/) || ($srcVar=~m/[a-zA-Z]+/ && $varHash{$destVar}!~m/PIC_X/) || ($srcVar=~m/ZEROES/ && $varHash{$destVar}!~m/PIC_9/)){
           $ret = "ERR $srcVar:$varHash{$srcVar}  $destVar:$varHash{$destVar}";
        }
       

      return $ret
    }
}

