#------------------------------------------------
# Function Initialization
# Read the input parameter and initialize
# the variables


sub init(){

    &EvaP( \@PDT, \@MM, \%cmdarg );
    $inputfile  = $cmdarg{'inputfile'} ;
    $outputfile  = $cmdarg{'outputfile'} ;
    $irNumber  = $cmdarg{'irnumber'} || "ALL";
    $debug  = $cmdarg{'debug'} ;
    $flag  = $cmdarg{'flag'} ;
  

    if(!-e $inputfile || !-r $inputfile){
        print "$inputfile not exists or readable\n";
        exit;
    }

    my $cpFile = "/tmp/$LOGNAME/TMPUNCOMP/";

   my ($filename)=$inputfile=~/([^\/]+)$/;
    $cpFile_file_Path = "$cpFile$filename";

    `cp -f $inputfile $cpFile_file_Path`;

    #`uncompress $cpFile_file_Path`;

   # $cpFile_file_Path =~ s/\.Z$//g;

   # print "[$cpFile_file_Path]\n";
  

    if($outputfile eq ""){
        my $inpFileName = basename($inputfile);
        $outputfile = "/tmp/$LOGNAME/$inpFileName\_out.err";
    }

    $inputfile = $cpFile_file_Path ;

    chomp($inputfile) if($inputfile);
    chomp($outputfile) if($outputfile);
    chomp($irNumber) if($irNumber);

    print "\nInput File : $inputfile\nOutput File : $outputfile\nDebug : $debug\nIr Number : $irNumber\n";
    open(OUTPUT, '>', "$outputfile") or die $!;  
}

#------------------------------------------------
# Function generateHash_variables
# To read the COBOL file and collect
# the data of COBOL variables and its datatypes


sub generateHash_variables(){

    my $var = "";
    my $datatype = "";

     
    open(DATA, '<', $cpFile_file_Path) or die "Couldn't open $cpFile_file_Path , $!";
    while(<DATA>) {
       ($var, $datatype) = "";
       #next if($_ =~ m/^\d{6}\*/ || $_ =~ m/^......\*/);
       next if($_ =~ m/^......\*/);

       if($_ =~ m/^.*\s+\d{2}\s+(.*)\s+(PIC\s+.).*\./){

           my $key = $1 ;
           my $value = $2 ;
           #my $varLen ;

           $key=~ s/^\s+|\s+$//g;
           $value=~ s/^\s+|\s+$//g;
           $value=~ s/\s+/_/g;
           #$value=~ s/^0{1,}//g;

           if($_ =~ m/^.*\s+\d{2}\s+(.*)\s+(PIC\s+.)(\(\d+\))\./){
               $varLen = $3 ;
               $varLen =~ s/\(//;
               $varLen =~ s/\)//;
               $varLen =~ s/^\s+|\s+$//g;
               $varLen=~ s/^0{1,}//g;
               $value = $value . "_" . $varLen ;
           }
 

           chomp($key);
           chomp($value);

          #print "$key|$value|$varLen\n";
          #print "$varLen\n";
           $varHash{$key} = $value ;
       }
    
       last if($_ =~ m/PROCEDURE\s+DIVISION\s+USING/);
  
    }
    close(DATA);
# print Dumper %varHash;


}


