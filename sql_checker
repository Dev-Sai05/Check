	if ($DBFILTBL_file_content=~m/VALUE "\s*$table_name\s*"/){
		print OP "Table $table_name is present in DBFILTBL table kindly use DBIO instead of select query.\n";
	}
	
	my ($index_name)=$sql_code=~m/[INDEX|INDEX_ASC]\(.*? (.*?)\)/;
	
	if ($index_name){
		print OP "INDEX NAME : $index_name\n";
	}
	elsif($DBFILTBL_file_content=~m/VALUE "\s*$table_name\s*"/ && !$index_name){
		print OP "Table $table_name is present in DBFILTBL table so index is mandatory.\n";
	}
	else{
		print OP "Index not found , manually verify the Index\n";
	}

	
	# Extract the part after WHERE clause
	if ($sql_code =~m/WHERE(.*)/s) {
		my $where_part = $1;
	
	# Find all variable-value pairs in the WHERE part (all except which includes between)
	while ($where_part =~m/^\s*(?:AND|\s*|\()\s*\b(\w+)\b\s*(?:=|>|<|>=|<=|!=|<>|\s+LIKE\s+|\s+IN[\s+|\s*\(])\s*(.*?)(?:$|\s+)/gm ) {
		my $variable = $1;
