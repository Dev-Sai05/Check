				print OP "\n--- cursor FLOW MATCHED ---\n";
			}else{
				print OP "\n--- cursor FLOW NOT MATCHED  ---\n";
		}
		}
		if ($sql_sql_query_var_flow=~m/$cobol_sql_query_var_flow/){
			print OP "\n--- FLOW MATCHED ---\n";
		}else{
			print OP "\n--- FLOW NOT MATCHED  ---\n";
		}



		if (@diff){
			for my $a(@diff){
				print OP "key mismatch , $a not present in index variables\n";
			}
		}

	}


	#working on SQL file data.pushing the sql file variables in sql_variables array 
	foreach my $line (split(/\n/, $sql_file_content)){
		$line=~s/^\W*//g;	
		if ($line =~m/\s+char\s*/i || $line =~m/\s+number\s*/i || $line =~m/\s+varchar\s*/i ) {
			if($line=~ m/^\s*(\w*)\s*(\w*)\s*\((.*?)\)/){
					my $temp_var3=$1;
					my $temp_var4=$2;
					my $temp_var5=$3;
					push @sql_variables, "$temp_var3 -> $temp_var4 ($temp_var5)";
				}
			}
		}
			##getting keys from sql file
		my(@vars_31)=$sql_file_content=~m/CONSTRAINT.*?\((.*?)\)/gs;
		for my $temp_key_variables (@vars_31){
		 if ($temp_key_variables =~m/,/){
			my @temp_key_variables_arr=split(/,/,$temp_key_variables);
			push @sql_key_variables,@temp_key_variables_arr;
		}
		else{
			push @sql_key_variables,$temp_key_variables;
			

		}
	}
	@sql_key_variables= map { $_=~ s/^\s+|\s+$//g ; $_ } @sql_key_variables;	
	#print Dumper \@sql_key_variables;
	#print OP Dumper \@sql_variables;
	#print Dumper \@variables_in_where;
	#print Dumper \@select_variables;
	

	print OP "\n--------------------------SELECT QUERY MATCHING---------------------------------\n";
	
	for my $temp_var(@select_into_arr_1){
	  $temp_var=~s/^\s*://;
	  if (grep /^$temp_var$/, @variables_in_where) {
                           print OP "variable $temp_var is present in INTO part also and in WHERE part also which is invalid.\n";
                        }
	}

	if ($select_ignore_flag eq 1){
		print OP "kindly Manually verify SELECT statement as it conatains SQL KEYWORDS";
		
	}
        
        ## checks if the there is any substriing in select section.
	if ($substring_error_flag eq 1){
		print OP "Substring is used in select section,Substring should not be used.";
		
	}

	my $len1=@select_arr_1;
	my $len2=@select_arr_2;
	if ($len1 eq $len2){
	for my $i(0..$len1-1){
		my $st_v1=$select_arr_1[$i];
		my $st_v2=$select_arr_2[$i];
		$st_v1 =~ s/^\s+|\s+$//g;
		$st_v2 =~ s/^\s+|\s+$//g;
		$st_v1 =~ s/^\s*://;
		$st_v2 =~ s/^\s*://;
		my $rv1 = match_the_two($st_v1,$st_v2,@sql_variables);
                if ($rv1=~m/mismatched/){
                       print OP "$st_v1 , $st_v2 , $rv1\n";
                }
	
	
	}
	}
	else{

	}

	for my $sql_select_temp (@select_variables){
		next if ($sql_select_temp eq "");
                if($sql_select_temp =~m/SUBSTR/){
 		   print OP "variable \"$sql_select_temp\",substring cannot be present in variable \n"; 
                   next;
                }
                
		if (!grep /^$sql_select_temp\s+/, @sql_variables) {
 		   print OP "Select query variable, $sql_select_temp is not present in sql file \n"; 
		}
                if ($sql_select_temp=~m//s){
 		   print OP "substring cannot be present in variable \n"; 
                }
	} 
	
	print OP "\n--------------------------WHERE QUERY MATCHING----------------------------------\n";
        
        ##looping on variables present in where section and process them    
	for my $t_v1(@variables_in_where){
		if($t_v1=~m/^(.*?)->(.*)/){
			my $t_v9=$1;
			my $t_v2=$2;
			$t_v9 =~ s/^\s+|\s+$//g;

                        if ($t_v9 =~m/SUBSTR/){
 			   print OP "variable \"$t_v9\", Substring should not be used.\n";
                           next; 
                        }
                        if ($t_v2 =~m/\|\|/){
 			   print OP "variable \"$t_v2\",  manually verify the variable.\n";
                           next; 
