        print OP "\n!!! ERROR PROCESSING SQL: $@ \n";  # Print the error message
    }
}
close ER;
close OP;
print "\nOutput_file: $output_file\n";
if (-e $error_file && -s $error_file > 0){
print "Error_file: $error_file\n\n";
