		push @variables_in_where,"$variable -> $value <o> $value1";
		push @variables_flow,$variable;
		push @variables_right_in_where,$value;
		push @variables_right_in_where,$value1;

	}
        
        # Find all variable-value pairs in the WHERE part (all except which includes between)
	while ($where_part =~m/^\s*(SUBSTR.*?)(?:=|>|<|>=|<=|!=|<>|\s+LIKE\s+|\s+IN[\s+|\s*\(])\s*(.*?)(?:$|\s+)/gm) {
		my $variable = $1;
		my $value = $2;
		#print "$variable -> $value\n";
		push @variables_in_where,"$variable -> $value";
		push @variables_flow,$variable;
		push @variables_right_in_where,$value;
	}

	}

	#print Dumper \@variables_in_where;
	#print Dumper \@variables_flow;
	#print Dumper \@variables_right_in_where;


	my $cobol_sql_query_var_flow=join(",",@variables_flow);
	#my $sql_filename=`grep "CREATE TABLE $table_name" /fns/d0/r/sql/*.sql`;
	my $sql_filename="/fns/d0/r/sql/".lc($table_name).".sql";
	$sql_filename=~s/:.*//isg; 
	$sql_filename =~ s/^\s+|\s+$//g;	
	if ($sql_filename){
		print OP "SQL FILENAME : $sql_filename\n";
	}
	else{
		print OP "corresponding sql file not found\n";
		next;	
	}
	
        my $sql_file_content;
	if (-e $sql_filename){ 	
	     open(my $ft,'<',$sql_filename) or die "Can't open file $!";
	     $sql_file_content = do { local $/; <$ft> };
	     close $ft;
	}
	else{
	    print OP "SQL file [$sql_filename] does not exist\n";
	    next; 
	}


	
	

        #index code checking if index is present in code or not
        #if present then it will match the flow of index with sql file index flow. 
	if (defined $index_name && $index_name ne ""){
		my ($index_chunk)=$sql_file_content=~m/CONSTRAINT\s*$index_name.*?\((.*?)\)/s;
		@flow_of_variables=split(/,/,$index_chunk);	
		@flow_of_variables= map { $_=~ s/^\s+|\s+$//g ; $_ } @flow_of_variables;


		my %hash;
		$hash{$_}= 1 for @flow_of_variables;
		my @diff=grep{!$hash{$_}} @variables_flow;

		my $sql_sql_query_var_flow=join(",",@flow_of_variables);

		print OP "\nSQL FLOW : $sql_sql_query_var_flow\n";
		print OP "COBOL FLOW : $cobol_sql_query_var_flow\n";
		if ($cursor_variables_flow){
