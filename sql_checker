			$t_v9 =~ s/^\s+|\s+$//g;
			$t_v9 =~ s/^\s*\(//g;
			$t_v9 =~ s/\)\s*$//g;
			$t_v2 =~ s/^\s+|\s+$//g;
			$t_v2 =~ s/\)\s*$//g;
			$t_v2 =~ s/^\s*\(//g;
			$t_v2 =~ s/^\s*://;
			#print "\nFIRST: $t_v2  ";
			#print "SECOND: $t_v9\n";
			
                        if ($t_v9 =~m/SUBSTR/){
 			   print OP "variable $t_v9, Substring should not be used.\n";
                           next; 
                        }
                         
                           

			if (!grep /^$t_v9$/, @sql_key_variables) {
 			   print OP "variable $t_v9 is not part of any key field which creates performance impact.\n"; 
			}

		        ##splitting variable names and their values for processing.	
			if ($t_v2=~m/<o>/){
				my @t_a1=split(/<o>/,$t_v2);
				my $rv1 = match_the_two($t_v9,$t_a1[0],@sql_variables); 
				my $rv2 = match_the_two($t_v9,$t_a1[1],@sql_variables);
				$t_a1[0]=~s/^\s*://;
				$t_a1[1]=~s/^\s*://;
				if ($rv1=~m/mismatched/){
					print OP "$t_v9 , $t_a1[0] $rv1";
				}
				if ($rv2=~m/mismatched/){
					print OP "$t_v9 , $t_a1[1] $rv2";
				}
			}
			elsif($t_v2=~m/,/){
				my @t_a1=split(/,/,$t_v2);
				my $rv1 = match_the_two($t_v9,$t_a1[0],@sql_variables); 
				my $rv2 = match_the_two($t_v9,$t_a1[1],@sql_variables);
				$t_a1[0]=~s/^\s*://;
				$t_a1[1]=~s/^\s*://;
				if ($rv1=~m/mismatched/){
					print OP "$t_v9 , $t_a1[0] , $rv1\n";
				}
				if ($rv2=~m/mismatched/){
