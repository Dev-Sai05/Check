sub match_the_two{
	my ($first,$second,@sql_variables)=@_;
  	my $flag=0;	
	my $datatype_1;
	my $datatype_2;
	my $length_1;
	my $length_2;
	$second=~s/^\s*://;
	$first =~ s/^\s+|\s+$//g;
	$second =~ s/^\s+|\s+$//g;

	my ($temp_first) = grep(/^$first\s*->/,@sql_variables);
        if ($temp_first){
        ($datatype_1)=$temp_first=~m/->\s*(.*?)\(/;
        ($length_1)=$temp_first=~m/\((.*?)\)/;
        #print"$temp_first $datatype_1 ------- $length_1\n";
        }
        else{	
		$flag=1;
                #print "variable $first not found in sql file , manually verify\n";
                #return 0;
        }
	

	if ($second=~m/'|"/){
		$datatype_2="X";
		$second=~s/['|"]//isg;
