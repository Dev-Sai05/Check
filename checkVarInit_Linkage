sub validateVar($$){
    my $src = $_[0];
    my $dest = $_[1];

    #print "$src	$dest	$varHash{$dest}{'VAL'}\n";
   
    if($src =~ m/^0$|ZEROES|ZEROS|ZERO/ && ($varHash{$dest}{'VAL'} !~ /^(PIC 9|PIC Z|PIC S9|PIC \*|PIC S|PIC \-)$/)){
         return "ERR";
    }
    elsif($src =~ m/\'N\'|\"N\"|SPACES|SPACE/ && ($varHash{$dest}{'VAL'} !~ /^(PIC X)$/)){
        return "ERR";
    }
}
