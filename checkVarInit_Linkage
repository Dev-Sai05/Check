sub writeOutput(){


    if($debug == 1){
        print OUTPUT "\n#Not Initialized Variables :\n\n";
        print OUTPUT "#Line No|Variable Name|Data Type\n";
    
        foreach my $entry (keys %varHash){
            if($varHash{$entry}{'INIT'} == 0){ 
                print OUTPUT "$varHash{$entry}{'LNO'}|$entry|$varHash{$entry}{'VAL'}\n";
            }
        }   
    }
        print OUTPUT "\n\n#Linkage Variables Should Not be Initialized In COBOL :\n\n";
        print OUTPUT "#Line No|Variable Name|Data Type\n";
        foreach my $entry (keys %varHash){
            if($varHash{$entry}{'INIT'} == 1){
                print OUTPUT "Initialized|$varHash{$entry}{'LNO'}|$entry|$varHash{$entry}{'VAL'}\n";
            }
        }
 
    close(OUTPUT);
}


sub init(){

    &EvaP( \@PDT, \@MM, \%cmdarg );
    $inputfile  = $cmdarg{'inputfile'} ;
    $outputfile  = $cmdarg{'outputfile'} ;
    $irNumber  = $cmdarg{'irnumber'} ;
    $debug  = $cmdarg{'debug'} ;


    if(!-e $inputfile || !-r $inputfile){
        print "$inputfile not exists or readable\n";
        exit;
    }

    if($irNumber eq ""){
        $irNumber = "ALL";
    }

    if($outputfile eq ""){
        my $inpFileName = basename($inputfile);
        $outputfile = "/tmp/$LOGNAME/$inpFileName\_Init.err";
    }
    chomp($inputfile) if($inputfile);
    chomp($outputfile) if($outputfile);
    chomp($irNumber) if($irNumber);
 
    print "\nInput File : $inputfile\nOutput File : $outputfile\nDeubg : $debug\nIr Number : $irNumber\n";
    open(OUTPUT, '>', "$outputfile") or die $!;
}


sub generateHash_variables(){

    my $var = "";
    my $datatype = "";
    my $startFlag = 0 ;
    my $lineNo = 0 ;
    my $readFlag = 0 ;
  
    #my $cmd = "awk '/ WORKING-STORAGE/{ f = 1 } f; /^...... LINKAGE SECTION|PROCEDURE DIVISION/{ f = 0 }' $inputfile";
    my $cmd = "awk '/ LINKAGE SECTION/{ f = 1 } f; /^...... PROCEDURE DIVISION/{ f = 0 }' $inputfile";
    #print "$cmd\n";

    #open(DATA, "$cmd |") or die "Couldn't open $inputfile , $!";
    open(DATA, '<', "$inputfile") or die "Couldn't open $inputfile , $!";
    while(<DATA>) {
       ($var, $datatype) = "";
       $lineNo = $lineNo + 1 ;
       if($_ =~ m/LINKAGE SECTION/){
           #print "$lineNo:$_";
           $readFlag = 1 ;
       }
   
       next if($readFlag != 1);
       if($readFlag == 1){
           #next if($_ =~ m/^......\*/);
#next if($_!~/WA-10990-IN-ACCT-NO/is);  


           if($_ =~ m/^.*\s+\d{2}\s+(.*)\s+(PIC\s+.).*\./ && $_ !~ m/FILLER/){

               my $key = $1 ;
               my $value = $2 ;

               $key=~ s/^\s+|\s+$//g;
               $value=~ s/^\s+|\s+$//g;

               $value=~ s/\s+/ /g;

               chomp($key);
               chomp($value);

               $varHash{$key}->{'VAL'} = $value ;
               $varHash{$key}->{'INIT'} = 0 ;
               $varHash{$key}->{'LNO'} = $lineNo ;
           }
           elsif($_ =~ m/(......)\s+01\s+([A-Z0-9\-]+)\.\s*$/){
               print OUTPUT "Kindly verfiy variable manually : $2\n";               
           }
       }
       if($_ =~ m/^...... PROCEDURE DIVISION/){
           #print "$lineNo:$_";
           last ;
       }
 
    }
    close(DATA);
}



